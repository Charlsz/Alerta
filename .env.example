# ── Datos ─────────────────────────────────────────────────────────────────────
# Token opcional para la API SODA de datos.gov.co.
# Sin token funciona, pero con token el rate limit es mayor.
SODA_APP_TOKEN=

# Ruta del archivo DuckDB. Por defecto usa data/alerta.duckdb
# Solo sobreescribir si se quiere usar una ruta diferente.
# DUCKDB_PATH=data/alerta.duckdb

# ── API Backend ───────────────────────────────────────────────────────────────
# Puerto donde corre FastAPI
API_PORT=8000

# ── Frontend Next.js ──────────────────────────────────────────────────────────
# URL base de la API consumida por el frontend.
# En desarrollo apunta a localhost; en producción a la URL real.
NEXT_PUBLIC_API_URL=http://localhost:8000
